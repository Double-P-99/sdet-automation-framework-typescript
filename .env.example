# Application URLs
BASE_URL=https://practicesoftwaretesting.com
API_BASE_URL=https://api.practicesoftwaretesting.com

# ── UI credentials (practicesoftwaretesting.com) ──────────────────────────────
UI_CUSTOMER_EMAIL=customer@practicesoftwaretesting.com
UI_CUSTOMER_PASSWORD=welcome01
UI_ADMIN_EMAIL=admin@practicesoftwaretesting.com
UI_ADMIN_PASSWORD=welcome01

# ── Backend API credentials (local seeded users) ──────────────────────────────
CUSTOMER_EMAIL=customer@test.com
CUSTOMER_PASSWORD=Test@12345
ADMIN_EMAIL=admin@test.com
ADMIN_PASSWORD=Test@12345

# CI flag (set to true in CI pipelines)
CI=false

# ── Backend: PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Host port for dev stack (change if 5432 is already in use on your machine)
POSTGRES_PORT=5432

# Host port for test stack (ephemeral, in-memory)
POSTGRES_TEST_PORT=5433

# ── Backend: Service ports ─────────────────────────────────────────────────────
AUTH_SERVICE_PORT=8001
ORDERS_SERVICE_PORT=8002

# ── Backend: Secret keys ───────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-change-in-production-minimum-32-chars
SECRET_KEY_TEST=test-secret-key-stable-for-integration-tests-32ch
